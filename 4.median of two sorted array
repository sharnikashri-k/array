class Solution {
    public double findMedianSortedArrays(int[] nums1, int[] nums2) {
        int m=nums1.length;
        int n=nums2.length;
        int[] merge=new int[m+n];
        for(int i=0;i<m;i++){
          merge[i]=nums1[i];
        }
         for(int i=0;i<n;i++){
            merge[m+i]=nums2[i];
         }    
         Arrays.sort(merge);
         int k=merge.length/2;
         if(merge.length%2!=0){
            return (double) merge[k];

         }  else{
            return (double)(merge[k-1]+merge[k])/2;
         }  

    }
}
