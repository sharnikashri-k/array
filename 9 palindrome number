class Solution {
    public boolean isPalindrome(int x) {
        int rev=0,temp,digit=x;
        while(x>0)
        {
          temp=x%10;
          rev=rev*10+temp;
          x=x/10;
        }
        if(digit==rev)
        {
        return true;
        }
        else
        {
         return false;   
        }
    }
}
